.task-card {
  background: #FFFFFF;
  border-radius: 8px;
  padding: 16px;
  margin-bottom: 10px;
}
.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}
.task-type {
  font-size: 14px;
  color: #07C160;
  font-weight: 500;
}
.task-reward {
  font-size: 18px;
  font-weight: 700;
  color: #FA5151;
}
.task-desc {
  font-size: 14px;
  color: #333;
  line-height: 1.5;
  margin-bottom: 10px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.task-footer {
  display: flex;
  justify-content: space-between;
  font-size: 12px;
  color: #999;
}
