page {
  --primary: #07C160;
  --danger: #FA5151;
  --warning: #FFC300;
  --text: #333333;
  --text-secondary: #999999;
  --bg: #F5F5F5;
  --white: #FFFFFF;
  --border: #E5E5E5;
  --radius: 8px;

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 14px;
  color: var(--text);
  background: var(--bg);
}

.container {
  padding: 16px;
  min-height: 100vh;
  box-sizing: border-box;
}
